generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CredentialType {
  directory_code
  barcode
  fob
  temp_code
}

enum CredentialStatus {
  active
  disabled
  lost
  revoked
}

enum HouseholdRole {
  primary
  secondary
  tertiary
  company_contact
}

enum AuditEntityType {
  resident_profile
  household_member
  gate_credential
}

enum AuditAction {
  create
  update
  revoke
  approve
  import
}

enum AccSourceSystem {
  wordpress_gf
}

enum AccDisposition {
  approved
  denied
  conditional
  duplicate
  canceled
  unknown
}

enum AccImportMode {
  full
  delta
  final
}

enum AccMatchMethod {
  auto_exact
  auto_scored
  manual_confirmed
  manual_rejected
}

enum AccMatchStatus {
  auto
  needs_review
  confirmed
  rejected
}

enum AccWorkflowRequestOrigin {
  portal_native
  gravity_cutover_import
}

enum AccWorkflowRequestStatus {
  initial_review
  needs_more_info
  committee_vote
  approved
  rejected
}

enum AccWorkflowDecision {
  approve
  reject
}

enum AccWorkflowVoteValue {
  approve
  reject
}

enum AccWorkflowActorRole {
  resident
  member
  chair
  admin
  system
}

enum AccWorkflowAttachmentScope {
  resident
  internal
}

enum AccWorkflowEventType {
  request_submitted
  request_updated
  more_info_requested
  resident_resubmitted
  initial_review_approved
  initial_review_rejected
  sent_to_committee_vote
  vote_cast
  chair_override_approved
  chair_override_rejected
  request_verified
  request_finalized
  attachment_added
  attachment_deleted
}

enum CapabilityEffect {
  allow
  deny
}

enum ResidencyType {
  owner
  tenant
  authorized_occupant
  unknown
}

enum ResidentState {
  current
  past
  unknown
}

enum AccessHolderCategory {
  owner_occupant
  owner_non_occupant
  tenant
  household_member
  trustee_or_owner_rep
  guardian
  vendor
  property_manager
  unspecified
}

enum LinkMatchConfidence {
  high
  medium
  low
  unresolved
}

enum LinkAuditEntityType {
  acc_request
  access_record
  residency
}

model Household {
  id                  String               @id @default(cuid())
  addressRaw          String?
  addressCanonical    String
  addressKey          String               @unique
  lotNumber           String?
  phase               String?
  residentProfiles    ResidentProfile[]
  residencies         Residency[]
  accRequests         AccRequest[]
  accWorkflowRequests AccWorkflowRequest[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([addressCanonical])
  @@index([lotNumber])
}

model Residency {
  id                  String               @id @default(cuid())
  householdId         String
  household           Household            @relation(fields: [householdId], references: [id], onDelete: Restrict)
  clerkUserId         String?
  residentType        ResidencyType        @default(unknown)
  startDate           DateTime?
  endDate             DateTime?
  isCurrent           Boolean              @default(true)
  sourceSystem        String?
  sourceRecordId      String?
  residentProfiles    ResidentProfile[]
  accRequests         AccRequest[]
  accWorkflowRequests AccWorkflowRequest[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([householdId, isCurrent])
  @@index([clerkUserId, isCurrent])
  @@index([startDate, endDate])
}

model LinkAudit {
  id                  String              @id @default(cuid())
  entityType          LinkAuditEntityType
  entityId            String
  previousHouseholdId String?
  newHouseholdId      String?
  previousResidencyId String?
  newResidencyId      String?
  reason              String?
  actorUserId         String?
  createdAt           DateTime            @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

model ResidentProfile {
  id                 String              @id @default(cuid())
  primaryUserId      String?
  residentCategory   String?
  includeInDirectory Boolean             @default(true)
  confidentialPhone  Boolean             @default(false)
  phase              String?
  addressNumber      String?
  streetName         String?
  addressFull        String?
  addressKey         String?
  householdId        String?
  household          Household?          @relation(fields: [householdId], references: [id], onDelete: SetNull)
  residencyId        String?
  residency          Residency?          @relation(fields: [residencyId], references: [id], onDelete: SetNull)
  residentState      ResidentState       @default(unknown)
  matchConfidence    LinkMatchConfidence @default(unresolved)
  matchMethod        String?
  matchedAt          DateTime?
  matchedBy          String?
  entryCode          String?
  comments           String?
  householdMembers   HouseholdMember[]
  credentials        GateCredential[]
  auditLogs          AccessAuditLog[]
  accMatches         ResidentAccMatch[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([addressKey])
  @@index([householdId])
  @@index([residencyId])
  @@index([residentState])
}

model HouseholdMember {
  id                String               @id @default(cuid())
  residentProfileId String
  residentProfile   ResidentProfile      @relation(fields: [residentProfileId], references: [id], onDelete: Cascade)
  role              HouseholdRole
  firstName         String?
  lastName          String?
  phone             String?
  email             String?
  isPrimaryContact  Boolean              @default(false)
  holderCategory    AccessHolderCategory @default(unspecified)
  holderState       ResidentState        @default(unknown)
  organizationName  String?
  startDate         DateTime?
  endDate           DateTime?
  notes             String?
  credentials       GateCredential[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([residentProfileId])
  @@index([holderCategory, holderState])
}

model GateCredential {
  id                String           @id @default(cuid())
  residentProfileId String
  residentProfile   ResidentProfile  @relation(fields: [residentProfileId], references: [id], onDelete: Cascade)
  householdMemberId String?
  householdMember   HouseholdMember? @relation(fields: [householdMemberId], references: [id], onDelete: SetNull)
  credentialType    CredentialType
  credentialLabel   String?
  credentialValue   String
  status            CredentialStatus @default(active)
  notes             String?
  issuedAt          DateTime?
  revokedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([residentProfileId])
  @@index([householdMemberId, status])
  @@index([status])
}

model AccessAuditLog {
  id                String           @id @default(cuid())
  residentProfileId String?
  residentProfile   ResidentProfile? @relation(fields: [residentProfileId], references: [id], onDelete: SetNull)
  actorUserId       String?
  entityType        AuditEntityType
  entityId          String
  action            AuditAction
  beforeJson        Json?
  afterJson         Json?
  reason            String?
  createdAt         DateTime         @default(now())

  @@index([residentProfileId])
  @@index([entityType, entityId])
}

model AccRequest {
  id                String                 @id @default(cuid())
  sourceSystem      AccSourceSystem
  sourceFormId      String
  sourceEntryId     String
  submittedAt       DateTime?
  updatedAtSource   DateTime?
  statusRaw         String?
  disposition       AccDisposition         @default(unknown)
  permitNumber      String?
  processDate       DateTime?
  workType          String?
  ownerName         String?
  ownerPhone        String?
  ownerEmail        String?
  authorizedRepName String?
  addressRaw        String?
  addressNumber     String?
  streetName        String?
  addressCanonical  String?
  addressKey        String?
  householdId       String?
  household         Household?             @relation(fields: [householdId], references: [id], onDelete: SetNull)
  residencyId       String?
  residency         Residency?             @relation(fields: [residencyId], references: [id], onDelete: SetNull)
  clerkUserId       String?
  residentState     ResidentState          @default(unknown)
  matchConfidence   LinkMatchConfidence    @default(unresolved)
  matchMethod       String?
  matchedAt         DateTime?
  matchedBy         String?
  phase             String?
  lot               String?
  description       String?
  notes             String?
  rawEntryJson      Json?
  importBatchId     String?
  lastSeenAt        DateTime               @default(now())
  attachments       AccRequestAttachment[]
  matches           ResidentAccMatch[]
  workflowRequest   AccWorkflowRequest?    @relation("ImportedAccRequestToWorkflow")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([sourceSystem, sourceFormId, sourceEntryId])
  @@index([addressCanonical])
  @@index([addressKey])
  @@index([householdId, submittedAt])
  @@index([residentState, submittedAt])
  @@index([matchConfidence, submittedAt])
  @@index([submittedAt])
  @@index([disposition])
  @@index([permitNumber])
}

model AccWorkflowRequest {
  id                      String                   @id @default(cuid())
  origin                  AccWorkflowRequestOrigin @default(portal_native)
  importedAccRequestId    String?                  @unique
  importedAccRequest      AccRequest?              @relation("ImportedAccRequestToWorkflow", fields: [importedAccRequestId], references: [id], onDelete: SetNull)
  residentClerkUserId     String
  householdId             String?
  household               Household?               @relation(fields: [householdId], references: [id], onDelete: SetNull)
  residencyId             String?
  residency               Residency?               @relation(fields: [residencyId], references: [id], onDelete: SetNull)
  residentNameSnapshot    String
  residentEmailSnapshot   String
  residentPhoneSnapshot   String?
  residentAddressSnapshot String?
  addressCanonical        String?
  addressKey              String?
  phase                   String?
  lot                     String?
  workType                String?
  title                   String?
  description             String?
  locationDetails         String?
  formDataJson            Json?
  authorizedRepName       String?
  estimatedStartDate      DateTime?
  estimatedCompletionDate DateTime?
  status                  AccWorkflowRequestStatus @default(initial_review)
  reviewCycle             Int                      @default(1)
  residentActionNote      String?
  voteDeadlineAt          DateTime?
  finalDecision           AccWorkflowDecision?
  finalDecisionAt         DateTime?
  finalDecisionByUserId   String?
  finalDecisionByRole     AccWorkflowActorRole?
  decisionNote            String?
  isVerified              Boolean                  @default(false)
  verifiedAt              DateTime?
  verifiedByUserId        String?
  verificationNote        String?
  lockedAt                DateTime?
  submittedAt             DateTime                 @default(now())
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  votes                   AccWorkflowVote[]
  attachments             AccWorkflowAttachment[]
  events                  AccWorkflowEvent[]

  @@index([residentClerkUserId, createdAt])
  @@index([householdId, createdAt])
  @@index([residencyId, createdAt])
  @@index([status, createdAt])
  @@index([status, voteDeadlineAt])
  @@index([addressKey])
}

model AccWorkflowVote {
  id          String               @id @default(cuid())
  requestId   String
  request     AccWorkflowRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewCycle Int
  voterUserId String
  vote        AccWorkflowVoteValue
  createdAt   DateTime             @default(now())

  @@unique([requestId, reviewCycle, voterUserId])
  @@index([requestId, reviewCycle, createdAt])
  @@index([voterUserId, createdAt])
}

model AccWorkflowAttachment {
  id               String                     @id @default(cuid())
  requestId        String
  request          AccWorkflowRequest         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedByUserId String?
  uploadedByRole   AccWorkflowActorRole
  scope            AccWorkflowAttachmentScope
  originalFilename String
  storageProvider  String
  storageKey       String
  storageBucket    String?
  mimeType         String
  fileSizeBytes    Int
  note             String?
  deletedAt        DateTime?
  deletedByUserId  String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([requestId, scope, createdAt])
  @@index([requestId, deletedAt])
}

model AccWorkflowEvent {
  id           String               @id @default(cuid())
  requestId    String
  request      AccWorkflowRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewCycle  Int
  eventType    AccWorkflowEventType
  actorUserId  String?
  actorRole    AccWorkflowActorRole
  note         String?
  metadataJson Json?
  createdAt    DateTime             @default(now())

  @@index([requestId, createdAt])
  @@index([requestId, reviewCycle, createdAt])
  @@index([eventType, createdAt])
}

model AccRequestAttachment {
  id               String     @id @default(cuid())
  accRequestId     String
  accRequest       AccRequest @relation(fields: [accRequestId], references: [id], onDelete: Cascade)
  fieldId          String
  url              String
  filename         String?
  mimeType         String?
  uploadedAtSource DateTime?
  createdAt        DateTime   @default(now())

  @@unique([accRequestId, fieldId, url])
  @@index([fieldId])
}

model AccImportRun {
  id                  String          @id @default(cuid())
  sourceSystem        AccSourceSystem
  sourceFormId        String
  mode                AccImportMode
  startedAt           DateTime        @default(now())
  finishedAt          DateTime?
  rowsRead            Int             @default(0)
  rowsUpserted        Int             @default(0)
  rowsUnchanged       Int             @default(0)
  attachmentsUpserted Int             @default(0)
  errorsJson          Json?
  triggeredBy         String?
  createdAt           DateTime        @default(now())
}

model ResidentAccMatch {
  id                String          @id @default(cuid())
  residentProfileId String
  residentProfile   ResidentProfile @relation(fields: [residentProfileId], references: [id], onDelete: Cascade)
  accRequestId      String
  accRequest        AccRequest      @relation(fields: [accRequestId], references: [id], onDelete: Cascade)
  matchScore        Int
  matchMethod       AccMatchMethod
  status            AccMatchStatus
  signalsJson       Json?
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([residentProfileId, accRequestId])
  @@index([status, matchScore])
  @@index([residentProfileId])
  @@index([accRequestId])
}

model UserCapabilityOverride {
  id            String           @id @default(cuid())
  clerkUserId   String
  capabilityKey String
  effect        CapabilityEffect
  reason        String?
  updatedBy     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([clerkUserId, capabilityKey])
  @@index([clerkUserId])
  @@index([capabilityKey])
}

model UserCapabilityOverrideAudit {
  id            String   @id @default(cuid())
  clerkUserId   String
  capabilityKey String
  beforeEffect  String?
  afterEffect   String?
  reason        String?
  actorUserId   String?
  createdAt     DateTime @default(now())

  @@index([clerkUserId, createdAt])
  @@index([capabilityKey, createdAt])
}
