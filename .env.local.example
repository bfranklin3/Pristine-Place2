# ── Sanity CMS Configuration ──────────────────────────────────
# 1. Create a Sanity project at https://www.sanity.io/manage
# 2. Copy your Project ID and Dataset name below
# 3. Generate an API token (Settings > API > Tokens) with Editor permissions
# 4. Add the token below (required for preview mode and mutations)

NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-api-token-here

# ── Email Configuration (Nodemailer) ─────────────────────────
# For Gmail:
# 1. Use App Password (not your regular Gmail password)
# 2. Enable 2FA on your Google account
# 3. Generate App Password: https://myaccount.google.com/apppasswords
# 4. Use the 16-character app password below

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_FROM=noreply@pristineplace.us

# ── Alternative: Resend (if you switch later) ─────────────────
# Uncomment these and update lib/email/service.ts to use Resend
# RESEND_API_KEY=re_...

# ── Other Services Examples ────────────────────────────────────
# Outlook/Office 365:
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587

# Yahoo Mail:
# EMAIL_HOST=smtp.mail.yahoo.com
# EMAIL_PORT=587

# Custom SMTP:
# EMAIL_HOST=mail.yourdomain.com
# EMAIL_PORT=587 (or 465 for SSL)

# ── WordPress Integration ─────────────────────────────────────
# Used by management pages that proxy WordPress/Gravity data.
WORDPRESS_API_URL=https://www.pristineplace.us/wp-json/wp/v2
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# JSON endpoint that returns the resident access report rows.
# Example custom endpoint: https://www.pristineplace.us/wp-json/pp/v1/resident-access-report
WORDPRESS_ACCESS_REPORT_URL=

# ── Database (Supabase Postgres + Prisma) ────────────────────
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI)
# Use the "Direct connection" URI for local migrations.
DATABASE_URL=
